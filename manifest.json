{
  "manifest_version": 3,
  "name": "Rebbit",
  "version": "2.0.0",
  "description": "Restyling Reddit experience with visual overhaul and power-user features",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.reddit.com/*",
    "*://reddit.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.reddit.com/*",
        "*://reddit.com/*"
      ],
      "css": [
        "styles/content.css"
      ],
      "js": [
        "scripts/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}